# mycel_vera_risk/docker/dev/.env
# Runtime + build configuration for dev environment.
# Secrets → .env.secrets (gitignored).

# ── Build vars ────────────────────────────────────────────────────────────
ROOT_MODULE_NAME=mycel_vera_risk
SUBMODULES=
CORE_VERSION=v0.1.0

# ── Port configuration ────────────────────────────────────────────────────
SERVICE_PORT=9110
WEB_PORT=9112
MCP_PORT=9111
MOBILE_PORT=9113

# ── Runtime environment ───────────────────────────────────────────────────
LOG_LEVEL=DEBUG
PYTHONOPTIMIZE=0

# ── Service metadata ──────────────────────────────────────────────────────
SERVICE_NAME=mycel_vera_risk_service
SERVICE_VERSION=0.1.0

# ── Observability (OTel) ─────────────────────────────────────────────────
# Service (Python, gRPC inside Docker network)
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
# Web (browser, HTTP on host)
VITE_OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
